# ── COPY THIS TO .env AND FILL IN ALL VALUES ──────────────

# Database
DB_PASSWORD=use_a_strong_password_here

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=generate_a_32_char_random_string_here_access
JWT_REFRESH_SECRET=generate_a_32_char_random_string_here_refresh

# App URLs
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
